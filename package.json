{
  "name": "codzilla-app",
  "version": "1.0.0",
  "description": "Codzilla Professional Management System",
  "author": "Codzilla",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.codzilla.app",
    "productName": "Codzilla App",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Codzilla"
    },
    "files": [
      "**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-adodb": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  }
}